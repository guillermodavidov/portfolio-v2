# Auto-detect text files and normalize line endings to LF
* text=auto

# Source code - always LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Config files
*.config.js text eol=lf
*.config.ts text eol=lf
tsconfig*.json text eol=lf
package.json text eol=lf
vite.config.ts text eol=lf

# Shell scripts - must be LF
*.sh text eol=lf

# Lock files - linguist-generated to reduce diff noise
package-lock.json linguist-generated

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.webm binary
